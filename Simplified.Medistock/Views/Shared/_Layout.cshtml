@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MediStock</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/medistock.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    
    <!-- ── Sidebar ── -->
    <aside class="ms-sidebar">

        <!-- Logo -->
        <a class="ms-sidebar-logo" asp-controller="Home" asp-action="Index">
            <div class="ms-sidebar-logo-icon">
                <i class="bi bi-capsule"></i>
            </div>
            <span class="ms-sidebar-logo-text">MediStock</span>
        </a>

        <!-- Navigation -->
        <ul class="ms-nav">

            <li class="ms-nav-label">Main</li>

            <li class="ms-nav-item">
                <a asp-controller="Home" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>

            <li class="ms-nav-label">Inventory</li>

            <li class="ms-nav-item">
                <a asp-controller="Categories" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")">
                    <i class="bi bi-tags"></i> Categories
                </a>
            </li>

            <li class="ms-nav-item">
                <a asp-controller="Products" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")">
                    <i class="bi bi-box-seam"></i> Products
                </a>
            </li>

            <li class="ms-nav-item">
                <a asp-controller="Suppliers" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Suppliers" ? "active" : "")">
                    <i class="bi bi-truck"></i> Suppliers
                </a>
            </li>

            <li class="ms-nav-item">
                <a asp-controller="StockAdjustments" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "StockAdjustments" ? "active" : "")">
                    <i class="bi bi-arrow-down-up"></i> Stock Adjustments
                </a>
            </li>

            <li class="ms-nav-label">Sales</li>

            <li class="ms-nav-item">
                <a asp-controller="Sales" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Sales" ? "active" : "")">
                    <i class="bi bi-cart3"></i> Sales
                </a>
            </li>

            <li class="ms-nav-item">
                <a asp-controller="Customers" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ? "active" : "")">
                    <i class="bi bi-people"></i> Customers
                </a>
            </li>

            <li class="ms-nav-item">
                <a asp-controller="PurchaseOrders" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "PurchaseOrders" ? "active" : "")">
                    <i class="bi bi-clipboard-check"></i> Purchase Orders
                </a>
            </li>

            <li class="ms-nav-label">System</li>

            <li class="ms-nav-item">
                <a asp-controller="Reports" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")">
                    <i class="bi bi-bar-chart-line"></i> Reports
                </a>
            </li>

            <li class="ms-nav-item">
                <a asp-controller="Users" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                    <i class="bi bi-shield-check"></i> User Management
                </a>
            </li>

            <li class="ms-nav-item">
                <a asp-controller="SystemLogs" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "SystemLogs" ? "active" : "")">
                    <i class="bi bi-file-text"></i> System Logs
                </a>
            </li>

        </ul>

        <!-- User section at bottom -->
        <div class="ms-sidebar-user">
            <div class="ms-user-avatar">AD</div>
            <div>
                <div class="ms-user-name">Admin</div>
                <div class="ms-user-role">Administrator</div>
            </div>

        </div>

    </aside>

    <!-- ── Main Content ── -->
    <div class="ms-main">

        <!-- Top Navbar -->
        <header class="ms-topbar">
            <div>
                <p class="ms-topbar-title">@(ViewData["Title"] ?? "Dashboard")</p>
                <p class="ms-topbar-subtitle">@DateTime.Now.ToString("dddd, MMMM dd yyyy")</p>
            </div>
            <div class="ms-topbar-right">
                <!-- Notification Bell -->
                <button style="width:36px;height:36px;border-radius:8px;border:1px solid var(--slate-200);background:white;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                    <i class="bi bi-bell" style="color:var(--slate-600);font-size:16px;"></i>
                </button>
                <!-- User Avatar -->
                <div class="ms-user-avatar">AD</div>
            </div>

            <div></div> <!-- left side spacer -->
            <div style="display:flex;align-items:center;gap:12px;">
                @if (SignInManager.IsSignedIn(User))
                {
                    <span style="font-size:13px;color:var(--slate-600);">
                        <i class="bi bi-person-circle"></i> @UserManager.GetUserName(User)
                    </span>
                    <form asp-area="Identity" asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Home")" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="ms-btn ms-btn-secondary ms-btn-sm">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                }
            </div>
        </header>

        <!-- Page Content -->
        <main class="ms-content">

            @* Global success/error alerts from TempData *@
            @if (TempData["Success"] != null)
            {
                <div class="ms-alert ms-alert-success">
                    <i class="bi bi-check-circle-fill"></i>
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="ms-alert ms-alert-danger">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    @TempData["Error"]
                </div>
            }

            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>