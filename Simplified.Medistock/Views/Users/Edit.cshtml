@model Simplified.Medistock.Models.ViewModels.EditUserViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="ms-page-header">
    <div>
        <h1 class="ms-page-title">Edit User</h1>
    </div>
    <a asp-action="Index" class="ms-btn ms-btn-secondary">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:600px;">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <div class="ms-form-section">
            <p class="ms-form-section-title">User Details</p>

            <div asp-validation-summary="ModelOnly"
                 class="ms-alert ms-alert-danger"
                 style="display:@(ViewData.ModelState.IsValid ? "none" : "block")">
            </div>

            <input asp-for="Id" type="hidden" />

            <div style="margin-bottom:20px;">
                <label asp-for="Email" class="ms-label">
                    Email <span style="color:var(--danger-text)">*</span>
                </label>
                <input asp-for="Email" class="ms-input" />
                <span asp-validation-for="Email" style="font-size:12px;color:var(--danger-text);"></span>
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="Role" class="ms-label">
                    Role <span style="color:var(--danger-text)">*</span>
                </label>
                <select asp-for="Role" asp-items="ViewBag.Roles" class="ms-input"></select>
                <span asp-validation-for="Role" style="font-size:12px;color:var(--danger-text);"></span>
            </div>
        </div>

        <div style="display:flex;gap:8px;">
            <button type="submit" class="ms-btn ms-btn-primary">
                <i class="bi bi-check-lg"></i> Save Changes
            </button>
            <a asp-action="Index" class="ms-btn ms-btn-secondary">Cancel</a>
        </div>
    </form>
</div>