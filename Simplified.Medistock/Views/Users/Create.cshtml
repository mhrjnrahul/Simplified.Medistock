@model Simplified.Medistock.Models.ViewModels.CreateUserViewModel

@{
    ViewData["Title"] = "New User";
}

<div class="ms-page-header">
    <div>
        <h1 class="ms-page-title">New User</h1>
    </div>
    <a asp-action="Index" class="ms-btn ms-btn-secondary">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:600px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="ms-form-section">
            <p class="ms-form-section-title">User Details</p>

            <div asp-validation-summary="ModelOnly"
                 class="ms-alert ms-alert-danger"
                 style="display:@(ViewData.ModelState.IsValid ? "none" : "block")">
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="Email" class="ms-label">
                    Email <span style="color:var(--danger-text)">*</span>
                </label>
                <input asp-for="Email" class="ms-input" placeholder="e.g. john@medistock.com" />
                <span asp-validation-for="Email" style="font-size:12px;color:var(--danger-text);"></span>
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="Password" class="ms-label">
                    Password <span style="color:var(--danger-text)">*</span>
                </label>
                <input asp-for="Password" type="password" class="ms-input" placeholder="Min. 6 characters" />
                <span asp-validation-for="Password" style="font-size:12px;color:var(--danger-text);"></span>
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="Role" class="ms-label">
                    Role <span style="color:var(--danger-text)">*</span>
                </label>
                <select asp-for="Role" asp-items="ViewBag.Roles" class="ms-input">
                    <option value="">-- Select Role --</option>
                </select>
                <span asp-validation-for="Role" style="font-size:12px;color:var(--danger-text);"></span>
            </div>
        </div>

        <div style="display:flex;gap:8px;">
            <button type="submit" class="ms-btn ms-btn-primary">
                <i class="bi bi-check-lg"></i> Create User
            </button>
            <a asp-action="Index" class="ms-btn ms-btn-secondary">Cancel</a>
        </div>
    </form>
</div>