@model Simplified.Medistock.Models.ViewModels.CategoryViewModel

@{
    ViewData["Title"] = "Category Details";
}

<div class="ms-page-header">
    <div>
        <h1 class="ms-page-title">Category Details</h1>
        <p class="ms-page-subtitle">Viewing category information</p>
    </div>
    <div style="display:flex;gap:8px;">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="ms-btn ms-btn-secondary">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Index" class="ms-btn ms-btn-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div style="max-width:600px;">
    <div class="ms-card">
        <div class="ms-card-header">
            <h2 class="ms-card-title">
                @if (!string.IsNullOrEmpty(Model.IconClass))
                {
                    <i class="@Model.IconClass me-2" style="color:var(--primary)"></i>
                }
                @Model.Name
            </h2>
            @if (Model.IsActive)
            {
                <span class="ms-badge ms-badge-success">Active</span>
            }
            else
            {
                <span class="ms-badge ms-badge-muted">Inactive</span>
            }
        </div>
        <div class="ms-card-body">
            <table style="width:100%;border-collapse:collapse;">
                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);width:140px;">Description</td>
                    <td style="padding:12px 0;font-size:14px;color:var(--slate-700);">@(Model.Description ?? "—")</td>
                </tr>
                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);">Icon Class</td>
                    <td style="padding:12px 0;">
                        @if (!string.IsNullOrEmpty(Model.IconClass))
                        {
                            <code style="font-size:13px;color:var(--slate-600);">@Model.IconClass</code>
                        }
                        else
                        {
                            <span style="color:var(--slate-400);">—</span>
                        }
                    </td>
                </tr>
                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);">Products</td>
                    <td style="padding:12px 0;">
                        <span class="ms-badge ms-badge-muted">
                            @Model.ProductCount product@(Model.ProductCount == 1 ? "" : "s")
                        </span>
                    </td>
                </tr>
                <tr>
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);">Created</td>
                    <td style="padding:12px 0;font-size:14px;color:var(--slate-400);">
                        @Model.CreatedAt.ToString("MMMM dd, yyyy")
                    </td>
                </tr>
            </table>
        </div>
    </div>
</div>