@model IEnumerable<Simplified.Medistock.Models.ViewModels.CategoryViewModel>

@{
    ViewData["Title"] = "Categories";
}

<!-- Page Header -->
<div class="ms-page-header">
    <div>
        <h1 class="ms-page-title">Categories</h1>
        <p class="ms-page-subtitle">Manage medicine categories</p>
    </div>
    <a asp-action="Create" class="ms-btn ms-btn-primary">
        <i class="bi bi-plus-lg"></i> Add Category
    </a>
</div>

<!-- Table -->
<div class="ms-table-wrapper">
    <table class="ms-table">
        <thead>
            <tr>
                <th>Category</th>
                <th>Description</th>
                <th>Products</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" style="text-align:center; color:var(--slate-400); padding:48px;">
                        <i class="bi bi-tags" style="font-size:32px;display:block;margin-bottom:8px;"></i>
                        No categories found. Add your first one.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var category in Model)
                {
                    <tr>
                        <td>
                            <div class="ms-cell-primary">
                                @if (!string.IsNullOrEmpty(category.IconClass))
                                {
                                    <i class="@category.IconClass me-2" style="color:var(--primary)"></i>
                                }
                                @category.Name
                            </div>
                        </td>
                        <td style="color:var(--slate-500)">
                            @(category.Description ?? "—")
                        </td>
                        <td>
                            <span class="ms-badge ms-badge-muted">
                                @category.ProductCount product@(category.ProductCount == 1 ? "" : "s")
                            </span>
                        </td>
                        <td>
                            @if (category.IsActive)
                            {
                                <span class="ms-badge ms-badge-success">Active</span>
                            }
                            else
                            {
                                <span class="ms-badge ms-badge-muted">Inactive</span>
                            }
                        </td>
                        <td class="ms-cell-meta">
                            @category.CreatedAt.ToString("MMM dd, yyyy")
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;">
                                <a asp-action="Details" asp-route-id="@category.Id"
                                   class="ms-btn ms-btn-secondary ms-btn-sm">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@category.Id"
                                   class="ms-btn ms-btn-secondary ms-btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button class="ms-btn ms-btn-danger ms-btn-sm"
                                        onclick="confirmDelete(@category.Id, '@category.Name')">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:1px solid var(--slate-100);">
            <div class="modal-header" style="border-bottom:1px solid var(--slate-100);">
                <h5 class="modal-title" style="font-size:15px;font-weight:600;color:var(--slate-800);">
                    <i class="bi bi-exclamation-triangle text-warning me-2"></i>Confirm Delete
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="color:var(--slate-600);font-size:14px;">
                Are you sure you want to delete <strong id="categoryName" style="color:var(--slate-800);"></strong>?
                This cannot be undone.
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--slate-100);gap:8px;">
                <button type="button" class="ms-btn ms-btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="ms-btn ms-btn-danger">
                        <i class="bi bi-trash3"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            document.getElementById('categoryName').textContent = name;
            document.getElementById('deleteForm').action = '/Categories/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}