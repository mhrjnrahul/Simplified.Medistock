@model Simplified.Medistock.Models.ViewModels.SupplierViewModel

@{
    ViewData["Title"] = "Supplier Details";
}

<div class="ms-page-header">
    <div>
        <h1 class="ms-page-title">Supplier Details</h1>
        <p class="ms-page-subtitle">Viewing supplier information</p>
    </div>
    <div style="display:flex;gap:8px;">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="ms-btn ms-btn-secondary">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Index" class="ms-btn ms-btn-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="d-flex justify-content-start align-items-center w-full gap-2">
    <div class="ms-card w-50 h-full">
        <div class="ms-card-header">
            <h2 class="ms-card-title">
                @Model.Name
            </h2>
            @if (Model.Status == Simplified.Medistock.Models.Enums.SupplierStatus.Active)
            {
                <span class="ms-badge ms-badge-success">Active</span>
            }
            else if (Model.Status == Simplified.Medistock.Models.Enums.SupplierStatus.Inactive)
            {
                <span class="ms-badge ms-badge-muted">Inactive</span>
            }
            else
            {
                <span class="ms-badge ms-badge-warning">Blacklisted</span>
            }
        </div>


        <div class="ms-card-body">
            <table style="width:100%;border-collapse:collapse;">
                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);width:140px;">Contact Person</td>
                    <td style="padding:12px 0;font-size:14px;color:var(--slate-700);">@(Model.ContactPerson ?? "—")</td>
                </tr>
                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);">Products</td>
                    <td style="padding:12px 0;">
                        <span class="ms-badge ms-badge-muted">
                            @Model.ProductCount product@(Model.ProductCount == 1 ? "" : "s")
                        </span>
                    </td>
                </tr>
                    
                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);">Email</td>
                    <td style="padding:12px 0;font-size:14px;color:var(--slate-700);">@(Model.Email ?? "—")</td>

                </tr>

                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);">Address</td>
                    <td style="padding:12px 0;font-size:14px;color:var(--slate-700);">
                        
                            @(string.Join(", ", new[] { Model.Address, Model.City, Model.Country }.Where(x => !string.IsNullOrEmpty(x))))
                        
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <div class="ms-card h-full w-50">
        <div class="ms-card-header">
            <h2 class="ms-card-title">
                General Details
            </h2>
        </div>

        <div class="ms-card-body">
            <table style="width:100%;border-collapse:collapse;">
                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);width:140px;">Tax Number</td>
                    <td style="padding:12px 0;font-size:14px;color:var(--slate-700);">@Model.TaxNumber</td>
                </tr>

                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);width:140px;">License Number</td>
                    <td style="padding:12px 0;font-size:14px;color:var(--slate-700);">@Model.LicenseNumber</td>
                </tr>

                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);width:140px;">Notes</td>
                    <td style="padding:12px 0;font-size:14px;color:var(--slate-700);">@Model.Notes</td>
                </tr>

                <tr style="border-bottom:1px solid var(--slate-100);">
                    <td style="padding:12px 0;font-size:13px;font-weight:600;color:var(--slate-500);width:140px;">Phone</td>
                    <td style="padding:12px 0;font-size:14px;color:var(--slate-700);">@Model.Phone</td>
                </tr>
            </table>
        </div>
    </div>
</div>