@model Simplified.Medistock.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stat Cards Row 1 — Inventory -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;">
    <div class="ms-card">
        <div class="ms-card-body" style="display:flex;align-items:center;gap:16px;">
            <div style="width:48px;height:48px;border-radius:12px;background:#eff6ff;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-capsule" style="font-size:22px;color:var(--primary);"></i>
            </div>
            <div>
                <p style="font-size:12px;color:var(--slate-500);margin:0;">Total Products</p>
                <p style="font-size:26px;font-weight:700;color:var(--slate-800);margin:0;line-height:1.2;">@Model.TotalProducts</p>
            </div>
        </div>
    </div>
    <div class="ms-card">
        <div class="ms-card-body" style="display:flex;align-items:center;gap:16px;">
            <div style="width:48px;height:48px;border-radius:12px;background:#fef3c7;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-truck" style="font-size:22px;color:#d97706;"></i>
            </div>
            <div>
                <p style="font-size:12px;color:var(--slate-500);margin:0;">Total Suppliers</p>
                <p style="font-size:26px;font-weight:700;color:var(--slate-800);margin:0;line-height:1.2;">@Model.TotalSuppliers</p>
            </div>
        </div>
    </div>
    <div class="ms-card">
        <div class="ms-card-body" style="display:flex;align-items:center;gap:16px;">
            <div style="width:48px;height:48px;border-radius:12px;background:#d1fae5;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-people" style="font-size:22px;color:#059669;"></i>
            </div>
            <div>
                <p style="font-size:12px;color:var(--slate-500);margin:0;">Total Customers</p>
                <p style="font-size:26px;font-weight:700;color:var(--slate-800);margin:0;line-height:1.2;">@Model.TotalCustomers</p>
            </div>
        </div>
    </div>
    <div class="ms-card">
        <div class="ms-card-body" style="display:flex;align-items:center;gap:16px;">
            <div style="width:48px;height:48px;border-radius:12px;background:#fee2e2;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-exclamation-triangle" style="font-size:22px;color:#dc2626;"></i>
            </div>
            <div>
                <p style="font-size:12px;color:var(--slate-500);margin:0;">Low Stock</p>
                <p style="font-size:26px;font-weight:700;color:#dc2626;margin:0;line-height:1.2;">@Model.LowStockCount</p>
            </div>
        </div>
    </div>
</div>

<!-- Stat Cards Row 2 — Sales -->
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;">
    <div class="ms-card">
        <div class="ms-card-body">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                <div>
                    <p style="font-size:12px;color:var(--slate-500);margin:0 0 4px;">Sales Today</p>
                    <p style="font-size:28px;font-weight:700;color:var(--slate-800);margin:0;line-height:1.2;">@Model.TotalSalesToday</p>
                    <p style="font-size:13px;color:var(--slate-500);margin:6px 0 0;">Rs. @Model.RevenueTotay.ToString("N2")</p>
                </div>
                <div style="width:40px;height:40px;border-radius:10px;background:#eff6ff;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-calendar-day" style="color:var(--primary);font-size:18px;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="ms-card">
        <div class="ms-card-body">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                <div>
                    <p style="font-size:12px;color:var(--slate-500);margin:0 0 4px;">Sales This Month</p>
                    <p style="font-size:28px;font-weight:700;color:var(--slate-800);margin:0;line-height:1.2;">@Model.TotalSalesThisMonth</p>
                    <p style="font-size:13px;color:var(--slate-500);margin:6px 0 0;">Rs. @Model.RevenueThisMonth.ToString("N2")</p>
                </div>
                <div style="width:40px;height:40px;border-radius:10px;background:#d1fae5;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-calendar-month" style="color:#059669;font-size:18px;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="ms-card">
        <div class="ms-card-body">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                <div>
                    <p style="font-size:12px;color:var(--slate-500);margin:0 0 4px;">All Time Revenue</p>
                    <p style="font-size:28px;font-weight:700;color:var(--primary);margin:0;line-height:1.2;">Rs. @Model.RevenueAllTime.ToString("N2")</p>
                    <p style="font-size:13px;color:var(--slate-500);margin:6px 0 0;">@Model.TotalSalesAllTime total sales</p>
                </div>
                <div style="width:40px;height:40px;border-radius:10px;background:#eff6ff;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-graph-up-arrow" style="color:var(--primary);font-size:18px;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="ms-card" style="margin-bottom:24px;">
    <div class="ms-card-body">
        <p style="font-size:12px;font-weight:600;color:var(--slate-500);margin:0 0 14px;text-transform:uppercase;letter-spacing:0.05em;">Quick Actions</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <a asp-controller="Sales" asp-action="Create" class="ms-btn ms-btn-primary" style="padding:12px 24px;font-size:14px;gap:8px;">
                <i class="bi bi-plus-lg"></i> New Sale
            </a>
            <a asp-controller="Products" asp-action="Create" class="ms-btn ms-btn-secondary" style="padding:12px 24px;font-size:14px;gap:8px;">
                <i class="bi bi-capsule"></i> Add Product
            </a>
            <a asp-controller="StockAdjustments" asp-action="Create" class="ms-btn ms-btn-secondary" style="padding:12px 24px;font-size:14px;gap:8px;">
                <i class="bi bi-arrow-left-right"></i> Adjust Stock
            </a>
            <a asp-controller="Customers" asp-action="Create" class="ms-btn ms-btn-secondary" style="padding:12px 24px;font-size:14px;gap:8px;">
                <i class="bi bi-person-plus"></i> Add Customer
            </a>
            <a asp-controller="Suppliers" asp-action="Create" class="ms-btn ms-btn-secondary" style="padding:12px 24px;font-size:14px;gap:8px;">
                <i class="bi bi-truck"></i> Add Supplier
            </a>
        </div>
    </div>
</div>

<!-- Alerts -->
@if (Model.ExpiredCount > 0 || Model.ExpiringSoonCount > 0 || Model.LowStockCount > 0)
{
    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:24px;">
        @if (Model.ExpiredCount > 0)
        {
            <div style="display:flex;align-items:center;gap:12px;padding:14px 18px;border-radius:10px;background:#fee2e2;border:1px solid #fecaca;">
                <i class="bi bi-x-circle-fill" style="color:#dc2626;font-size:18px;flex-shrink:0;"></i>
                <div style="flex:1;">
                    <span style="font-weight:600;color:#991b1b;font-size:14px;">@Model.ExpiredCount product@(Model.ExpiredCount == 1 ? "" : "s") have expired.</span>
                    <span style="color:#b91c1c;font-size:13px;margin-left:6px;">Please remove them from inventory immediately.</span>
                </div>
                <a asp-controller="Products" asp-action="Index" style="color:#dc2626;font-size:13px;font-weight:600;white-space:nowrap;">View Products →</a>
            </div>
        }
        @if (Model.ExpiringSoonCount > 0)
        {
            <div style="display:flex;align-items:center;gap:12px;padding:14px 18px;border-radius:10px;background:#fef3c7;border:1px solid #fde68a;">
                <i class="bi bi-clock-history" style="color:#d97706;font-size:18px;flex-shrink:0;"></i>
                <div style="flex:1;">
                    <span style="font-weight:600;color:#92400e;font-size:14px;">@Model.ExpiringSoonCount product@(Model.ExpiringSoonCount == 1 ? "" : "s") expiring within 30 days.</span>
                </div>
                <a asp-controller="Products" asp-action="Index" style="color:#d97706;font-size:13px;font-weight:600;white-space:nowrap;">View Products →</a>
            </div>
        }
        @if (Model.LowStockCount > 0)
        {
            <div style="display:flex;align-items:center;gap:12px;padding:14px 18px;border-radius:10px;background:#fef3c7;border:1px solid #fde68a;">
                <i class="bi bi-box-seam" style="color:#d97706;font-size:18px;flex-shrink:0;"></i>
                <div style="flex:1;">
                    <span style="font-weight:600;color:#92400e;font-size:14px;">@Model.LowStockCount product@(Model.LowStockCount == 1 ? "" : "s") below reorder level.</span>
                </div>
                <a asp-controller="Products" asp-action="Index" style="color:#d97706;font-size:13px;font-weight:600;white-space:nowrap;">View Products →</a>
            </div>
        }
    </div>
}

<!-- Bottom Grid -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;">
    <!-- Recent Sales -->
    <div class="ms-card">
        <div class="ms-card-header">
            <h2 class="ms-card-title">Recent Sales</h2>
            <a asp-controller="Sales" asp-action="Index" class="ms-btn ms-btn-secondary ms-btn-sm">View All</a>
        </div>
        <div class="ms-card-body" style="padding:0;">
            @if (!Model.RecentSales.Any())
            {
                <div style="text-align:center;padding:40px;color:var(--slate-400);">
                    <i class="bi bi-receipt" style="font-size:28px;display:block;margin-bottom:8px;"></i>
                    <p style="font-size:13px;margin:0;">No sales yet.</p>
                </div>
            }
            else
            {
                <table class="ms-table">
                    <thead>
                        <tr>
                            <th>Sale #</th>
                            <th>Customer</th>
                            <th style="text-align:right;">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sale in Model.RecentSales)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Sales" asp-action="Details" asp-route-id="@sale.Id"
                                       style="color:var(--primary);font-weight:600;font-size:13px;">
                                        @sale.SaleNumber
                                    </a>
                                    <div style="font-size:11px;color:var(--slate-400);margin-top:2px;">@sale.SaleDate.ToString("MMM dd, yyyy")</div>
                                </td>
                                <td style="font-size:13px;color:var(--slate-600);">@sale.CustomerName</td>
                                <td style="text-align:right;font-weight:600;font-size:13px;color:var(--slate-800);">Rs. @sale.GrandTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Low Stock -->
    <div class="ms-card">
        <div class="ms-card-header">
            <h2 class="ms-card-title">Low Stock</h2>
            <a asp-controller="StockAdjustments" asp-action="Create" class="ms-btn ms-btn-primary ms-btn-sm">
                <i class="bi bi-plus-lg"></i> Adjust Stock
            </a>
        </div>
        <div class="ms-card-body" style="padding:0;">
            @if (!Model.LowStockProducts.Any())
            {
                <div style="text-align:center;padding:40px;color:var(--slate-400);">
                    <i class="bi bi-check-circle" style="font-size:28px;display:block;margin-bottom:8px;color:#059669;"></i>
                    <p style="font-size:13px;margin:0;">All products are well stocked.</p>
                </div>
            }
            else
            {
                <table class="ms-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>In Stock</th>
                            <th>Reorder At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.LowStockProducts)
                        {
                            <tr>
                                <td>
                                    <div class="ms-cell-primary">@product.Name</div>
                                    <div style="font-size:11px;color:var(--slate-400);margin-top:2px;">@product.CategoryName</div>
                                </td>
                                <td>
                                    @if (product.Quantity == 0)
                                    {
                                        <span class="ms-badge ms-badge-danger">Out of Stock</span>
                                    }
                                    else
                                    {
                                        <span class="ms-badge ms-badge-warning">@product.Quantity left</span>
                                    }
                                </td>
                                <td style="font-size:13px;color:var(--slate-500);">@product.ReorderLevel</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<!-- Expiring Soon -->
@if (Model.ExpiringSoonProducts.Any())
{
    <div class="ms-card" style="margin-bottom:24px;">
        <div class="ms-card-header">
            <h2 class="ms-card-title">Expiring Soon</h2>
        </div>
        <div class="ms-card-body" style="padding:0;">
            <table class="ms-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Qty</th>
                        <th>Expires</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.ExpiringSoonProducts)
                    {
                        <tr>
                            <td><div class="ms-cell-primary">@product.Name</div></td>
                            <td class="ms-cell-meta">@product.CategoryName</td>
                            <td class="ms-cell-meta">@product.Quantity</td>
                            <td>
                                <span class="ms-badge ms-badge-warning">
                                    @product.ExpiryDate?.ToString("MMM dd, yyyy")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}