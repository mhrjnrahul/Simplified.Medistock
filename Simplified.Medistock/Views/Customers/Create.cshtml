@model Simplified.Medistock.Models.ViewModels.CreateCustomerViewModel

@{
    ViewData["Title"] = "Add Customer";
}

<div class="ms-page-header">
    <div>
        <h1 class="ms-page-title">Add Customer</h1>
        <p class="ms-page-subtitle">Create new customer</p>
    </div>
    <a asp-action="Index" class="ms-btn ms-btn-secondary">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:600px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="ms-form-section">
            <p class="ms-form-section-title">Customer Details</p>

            <div asp-validation-summary="ModelOnly"
                 class="ms-alert ms-alert-danger"
                 style="display:@(ViewData.ModelState.IsValid ? "none" : "block")">
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="FirstName" class="ms-label">
                    First Name <span style="color:var(--danger-text)">*</span>
                </label>
                <input asp-for="FirstName" class="ms-input" placeholder="e.g. John" />
                <span asp-validation-for="FirstName" style="font-size:12px;color:var(--danger-text);"></span>
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="LastName" class="ms-label">Last Name<span style="color:var(--danger-text)">*</span></label>
                <input asp-for="LastName" class="ms-input" placeholder="e.g. Smith" />
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="Email" class="ms-label">Email</label>
                <input asp-for="Email" class="ms-input" placeholder="maharjanrahul58@gmail.com" />

            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="Phone" class="ms-label">Phone</label>
                <input asp-for="Phone" class="ms-input" placeholder="e.g. 9800000000" />
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="Address" class="ms-label">Address</label>
                <input asp-for="Address" class="ms-input" placeholder="e.g. Patan Dhoka" />
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="City" class="ms-label">City</label>
                <input asp-for="City" class="ms-input" placeholder="e.g. Lalitpur" />
            </div>


            <div style="margin-bottom:20px;">
                <label asp-for="DateOfBirth" class="ms-label">Date of Birth</label>
                <input asp-for="DateOfBirth" type="date" class="ms-input" placeholder="e.g. 2004-07-18" />
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="CustomerType" class="ms-label">Customer Type</label>
                <select asp-for="CustomerType" asp-items="ViewBag.CustomerTypes" class="ms-input"></select>
            </div>



            <div style="margin-bottom:20px;">
                <label asp-for="InsuranceNumber" class="ms-label">Insurance Number</label>
                <input asp-for="InsuranceNumber" class="ms-input"
                       placeholder="Your insurance number here" />
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="InsuranceProvider" class="ms-label">Insurance Provider</label>
                <input asp-for="InsuranceProvider" class="ms-input" placeholder="e.g Sanima Insurance" />
            </div>
        </div>

        <div style="display:flex;gap:8px;">
            <button type="submit" class="ms-btn ms-btn-primary">
                <i class="bi bi-check-lg"></i> Save Customer
            </button>
            <a asp-action="Index" class="ms-btn ms-btn-secondary">Cancel</a>
        </div>

    </form>
</div>