@model Simplified.Medistock.Models.ViewModels.CreateProductViewModel

@{
    ViewData["Title"] = "Add Product";
}

<div class="ms-page-header">
    <div>
        <h1 class="ms-page-title">Add Product</h1>
        <p class="ms-page-subtitle">Add a new medicine to inventory</p>
    </div>
    <a asp-action="Index" class="ms-btn ms-btn-secondary">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly"
         class="ms-alert ms-alert-danger"
         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")">
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">

        <!-- Left Column -->
        <div>
            <!-- Basic Info -->
            <div class="ms-form-section">
                <p class="ms-form-section-title">Basic Information</p>

                <div style="margin-bottom:16px;">
                    <label asp-for="Name" class="ms-label">Name <span style="color:var(--danger-text)">*</span></label>
                    <input asp-for="Name" class="ms-input" placeholder="e.g. Paracetamol 500mg" />
                    <span asp-validation-for="Name" style="font-size:12px;color:var(--danger-text);"></span>
                </div>

                <div style="margin-bottom:16px;">
                    <label asp-for="GenericName" class="ms-label">Generic Name</label>
                    <input asp-for="GenericName" class="ms-input" placeholder="e.g. Acetaminophen" />
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                    <div>
                        <label asp-for="SKU" class="ms-label">SKU <span style="color:var(--danger-text)">*</span></label>
                        <input asp-for="SKU" class="ms-input" placeholder="e.g. MED-001" />
                        <span asp-validation-for="SKU" style="font-size:12px;color:var(--danger-text);"></span>
                    </div>
                    <div>
                        <label asp-for="Barcode" class="ms-label">Barcode</label>
                        <input asp-for="Barcode" class="ms-input" placeholder="Optional" />
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                    <div>
                        <label asp-for="CategoryId" class="ms-label">Category <span style="color:var(--danger-text)">*</span></label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="ms-input">
                            <option value="">— Select Category —</option>
                        </select>
                        <span asp-validation-for="CategoryId" style="font-size:12px;color:var(--danger-text);"></span>
                    </div>
                    <div>
                        <label asp-for="SupplierId" class="ms-label">Supplier</label>
                        <select asp-for="SupplierId" asp-items="ViewBag.Suppliers" class="ms-input">
                            <option value="">— Select Supplier —</option>
                        </select>
                    </div>
                </div>

                <div style="margin-bottom:16px;">
                    <label asp-for="Manufacturer" class="ms-label">Manufacturer</label>
                    <input asp-for="Manufacturer" class="ms-input" placeholder="e.g. GSK" />
                </div>

                <div>
                    <label asp-for="Description" class="ms-label">Description</label>
                    <textarea asp-for="Description" class="ms-input" rows="3" style="resize:vertical;"></textarea>
                </div>
            </div>

            <!-- Pricing -->
            <div class="ms-form-section">
                <p class="ms-form-section-title">Pricing</p>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                    <div>
                        <label asp-for="CostPrice" class="ms-label">Cost Price <span style="color:var(--danger-text)">*</span></label>
                        <input asp-for="CostPrice" class="ms-input" type="number" step="0.01" placeholder="0.00" />
                        <span asp-validation-for="CostPrice" style="font-size:12px;color:var(--danger-text);"></span>
                    </div>
                    <div>
                        <label asp-for="SellingPrice" class="ms-label">Selling Price <span style="color:var(--danger-text)">*</span></label>
                        <input asp-for="SellingPrice" class="ms-input" type="number" step="0.01" placeholder="0.00" />
                        <span asp-validation-for="SellingPrice" style="font-size:12px;color:var(--danger-text);"></span>
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div>
                        <label asp-for="DiscountPercent" class="ms-label">Discount %</label>
                        <input asp-for="DiscountPercent" class="ms-input" type="number" step="0.01" placeholder="0" />
                    </div>
                    <div>
                        <label asp-for="TaxPercent" class="ms-label">Tax %</label>
                        <input asp-for="TaxPercent" class="ms-input" type="number" step="0.01" placeholder="0" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div>
            <!-- Stock -->
            <div class="ms-form-section">
                <p class="ms-form-section-title">Stock Information</p>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                    <div>
                        <label asp-for="Quantity" class="ms-label">Initial Quantity <span style="color:var(--danger-text)">*</span></label>
                        <input asp-for="Quantity" class="ms-input" type="number" placeholder="0" />
                        <span asp-validation-for="Quantity" style="font-size:12px;color:var(--danger-text);"></span>
                    </div>
                    <div>
                        <label asp-for="ReorderLevel" class="ms-label">Reorder Level</label>
                        <input asp-for="ReorderLevel" class="ms-input" type="number" placeholder="10" />
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                    <div>
                        <label asp-for="MaxStockLevel" class="ms-label">Max Stock Level</label>
                        <input asp-for="MaxStockLevel" class="ms-input" type="number" placeholder="1000" />
                    </div>
                    <div>
                        <label asp-for="UnitOfMeasure" class="ms-label">Unit of Measure</label>
                        <input asp-for="UnitOfMeasure" class="ms-input" placeholder="e.g. Tablets, ml" />
                    </div>
                </div>

                <div>
                    <label asp-for="Status" class="ms-label">Status</label>
                    <select asp-for="Status" asp-items="ViewBag.Statuses" class="ms-input"></select>
                    <p class="ms-hint">Auto-set to Out of Stock if quantity is 0</p>
                </div>
            </div>

            <!-- Medicine Specific -->
            <div class="ms-form-section">
                <p class="ms-form-section-title">Medicine Details</p>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                    <div>
                        <label asp-for="BatchNumber" class="ms-label">Batch Number</label>
                        <input asp-for="BatchNumber" class="ms-input" placeholder="e.g. BT-2024-001" />
                    </div>
                    <div>
                        <label asp-for="ExpiryDate" class="ms-label">Expiry Date</label>
                        <input asp-for="ExpiryDate" class="ms-input" type="date" />
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                    <div>
                        <label asp-for="DosageForm" class="ms-label">Dosage Form</label>
                        <select asp-for="DosageForm" asp-items="ViewBag.DosageForms" class="ms-input">
                            <option value="">— Select —</option>
                        </select>
                    </div>
                    <div>
                        <label asp-for="Strength" class="ms-label">Strength</label>
                        <input asp-for="Strength" class="ms-input" placeholder="e.g. 500mg" />
                    </div>
                </div>

                <div style="margin-bottom:16px;">
                    <label asp-for="StorageConditions" class="ms-label">Storage Conditions</label>
                    <input asp-for="StorageConditions" class="ms-input" placeholder="e.g. Store below 25°C" />
                </div>

                <div style="display:flex;align-items:center;gap:10px;">
                    <input asp-for="RequiresPrescription" type="checkbox"
                           style="width:16px;height:16px;accent-color:var(--primary);" />
                    <label asp-for="RequiresPrescription" class="ms-label" style="margin:0;">
                        Requires Prescription
                    </label>
                </div>
            </div>
        </div>
    </div>

    <!-- Form Actions -->
    <div style="display:flex;gap:8px;margin-top:8px;">
        <button type="submit" class="ms-btn ms-btn-primary">
            <i class="bi bi-check-lg"></i> Save Product
        </button>
        <a asp-action="Index" class="ms-btn ms-btn-secondary">Cancel</a>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}