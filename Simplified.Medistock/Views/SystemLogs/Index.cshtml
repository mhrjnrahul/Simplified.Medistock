@model IEnumerable<Simplified.Medistock.Models.ViewModels.SystemLogViewModel>
@{
    ViewData["Title"] = "System Logs";
}

<div class="ms-page-header">
    <div>
        <h1 class="ms-page-title">System Logs</h1>
        <p class="ms-page-subtitle">Audit trail of system activity</p>
    </div>
</div>

<div class="ms-table-wrapper">
    <table class="ms-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Level</th>
                <th>Message</th>
                <th>Source</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" style="text-align:center;color:var(--slate-400);padding:48px;">
                        <i class="bi bi-journal-text" style="font-size:32px;display:block;margin-bottom:8px;"></i>
                        No logs found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var log in Model)
                {
                    <tr>
                        <td class="ms-cell-meta">@log.Timestamp.ToString("MMM dd, yyyy hh:mm tt")</td>
                        <td>
                            @if (log.Level == Simplified.Medistock.Models.Enums.AppLogLevel.Info)
                            {
                                <span class="ms-badge ms-badge-success">Info</span>
                            }
                            else if (log.Level == Simplified.Medistock.Models.Enums.AppLogLevel.Warning)
                            {
                                <span class="ms-badge ms-badge-warning">Warning</span>
                            }
                            else if (log.Level == Simplified.Medistock.Models.Enums.AppLogLevel.Error)
                            {
                                <span class="ms-badge ms-badge-danger">Error</span>
                            }
                            else
                            {
                                <span class="ms-badge ms-badge-muted">@log.Level</span>
                            }
                        </td>
                        <td><div class="ms-cell-primary">@log.Message</div></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@log.Id"
                               class="ms-btn ms-btn-secondary ms-btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>